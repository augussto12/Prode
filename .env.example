# ─── Base de datos (hostname interno Docker) ───
DATABASE_URL=postgresql://USER:PASSWORD@postgres-db:5432/DB_NAME?schema=prode&sslmode=disable

# ─── Secrets ───
JWT_SECRET=your-jwt-secret-here
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Frontend URL (para CORS) ───
FRONTEND_URL=http://YOUR_VPS_IP:8093
