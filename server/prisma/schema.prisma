generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  ADMIN
  SUPERADMIN
}

// MatchStatus enum eliminado — ya no hay tabla Match

model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  username      String        @unique
  password      String
  displayName   String
  avatar        String?
  role          Role          @default(PLAYER)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Personal theme customization
  themePrimary      String?   @default("#6366f1")
  themeSecondary    String?   @default("#8b5cf6")
  themeAccent       String?   @default("#f59e0b")
  themeBgFrom       String?   @default("#0f172a")
  themeBgTo         String?   @default("#1e1b4b")

  predictions   Prediction[]
  groupUsers        GroupUser[]
  favorites         Favorite[]
  messages          Message[]
  dreamTeams        DreamTeam[]
  outrightPredictions OutrightPrediction[]

  @@index([email])
  @@index([username])
}

// Para equipos/selecciones favoritas
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  teamName  String   // Ej: "Argentina", "Brasil"
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, teamName])
}

model Competition {
  id          Int      @id @default(autoincrement())
  externalId  Int
  name        String
  logo        String?
  season      Int      @default(2022)
  
  groups      Group[]
  dreamTeams  DreamTeam[]
  outrights   OutrightPrediction[]
  playerStats PlayerCompetitionStats[]
  predictions Prediction[]

  @@unique([externalId, season])
}

model Group {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
  inviteCode    String        @unique @default(uuid())
  isPublic      Boolean       @default(false)
  createdById   Int

  // Theme customization
  primaryColor    String      @default("#6366f1")  
  secondaryColor  String      @default("#8b5cf6")  
  accentColor     String      @default("#f59e0b")  
  bgGradientFrom  String      @default("#0f172a")  
  bgGradientTo    String      @default("#1e1b4b")  
  logoUrl         String?

  // Modulos extra permitidos
  allowMoreShots      Boolean @default(true)
  allowMoreCorners    Boolean @default(true)
  allowMorePossession Boolean @default(true)
  allowMoreFouls      Boolean @default(true)
  allowMoreCards      Boolean @default(true)
  allowMoreOffsides   Boolean @default(true)
  allowMoreSaves      Boolean @default(true)

  competitionId Int
  competition   Competition   @relation(fields: [competitionId], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  groupUsers    GroupUser[]
  messages      Message[]

  @@index([inviteCode])
}

model GroupUser {
  id            Int           @id @default(autoincrement())
  userId        Int
  groupId       Int
  totalPoints   Int           @default(0)
  joinedAt      DateTime      @default(now())
  isAdmin       Boolean       @default(false)
  isBanned      Boolean       @default(false)
  bannedAt      DateTime?

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group         Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId, totalPoints(sort: Desc)])
}

model Team {
  id          Int      @id @default(autoincrement())
  externalId  Int      @unique
  name        String
  code        String?
  logo        String?
  country     String?
  flag        String?
  
  players     Player[]
  coaches     Coach[]
  
  @@index([externalId])
}

// Match y MatchEvent ELIMINADOS — la data de partidos viene del Explorer API en tiempo real

model Prediction {
  id                  Int           @id @default(autoincrement())
  userId              Int
  externalFixtureId   Int           // ID del fixture en API-Football
  competitionId       Int           // Liga/torneo al que pertenece

  homeGoals       Int?
  awayGoals       Int?
  winner          String?
  doubleChance    String?

  btts            Boolean?
  overUnder25     String?
  moreShots       String?
  moreCorners     String?   // HOME, AWAY, EQUAL
  morePossession  String?   // HOME, AWAY, EQUAL
  moreFouls       String?   // HOME, AWAY, EQUAL
  moreCards       String?   // HOME, AWAY, EQUAL
  moreOffsides    String?   // HOME, AWAY, EQUAL
  moreSaves       String?   // HOME, AWAY, EQUAL

  isJoker         Boolean   @default(false)
  
  basePoints      Int       @default(0)
  pointsEarned    Int       @default(0)
  moreShotsHit    Boolean?  // null=not calculated, true=correct, false=wrong
  moreCornersHit  Boolean?
  morePossessionHit Boolean?
  moreFoulsHit    Boolean?
  moreCardsHit    Boolean?
  moreOffsidesHit Boolean?
  moreSavesHit    Boolean?
  isCalculated    Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  competition     Competition @relation(fields: [competitionId], references: [id])

  @@unique([userId, externalFixtureId]) 
  @@index([externalFixtureId])
  @@index([userId])
  @@index([competitionId])
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  userId    Int
  groupId   Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model ScoringConfig {
  id            Int      @id @default(autoincrement())
  exactScore    Int      @default(5)
  correctWinner Int      @default(2)
  doubleChance  Int      @default(0) // Legacy
  btts          Int      @default(0) // Legacy
  moreShots     Int      @default(1)
  moreCorners   Int      @default(1)
  morePossession Int     @default(1)
  moreFouls     Int      @default(1)
  moreCards     Int      @default(1)
  moreOffsides  Int      @default(1)
  moreSaves     Int      @default(1)
  overUnder     Int      @default(0) // Legacy
}

model Player {
  id          Int      @id @default(autoincrement())
  externalId  Int?     @unique
  name        String
  teamId      Int?
  team        Team?    @relation(fields: [teamId], references: [id])
  country     String
  position    String   // GK, DEF, MID, FWD
  image       String?
  photo       String?  // URL from API
  number      Int?
  age         Int?
  price       Float?   // Optional for budget caps
  
  // Stats por competencia (tabla separada)
  stats       PlayerCompetitionStats[]

  // Reverse relations to DreamTeam slots
  gkTeams     DreamTeam[] @relation("GK")
  def1Teams   DreamTeam[] @relation("DEF1")
  def2Teams   DreamTeam[] @relation("DEF2")
  mid1Teams   DreamTeam[] @relation("MID1")
  mid2Teams   DreamTeam[] @relation("MID2")
  fwd1Teams   DreamTeam[] @relation("FWD1")
  fwd2Teams   DreamTeam[] @relation("FWD2")

  // Reverse relations to Outrights
  topScorers  OutrightPrediction[] @relation("TopScorer")
  bestPlayers OutrightPrediction[] @relation("BestPlayer")

  @@index([teamId])
}

model Coach {
  id          Int      @id @default(autoincrement())
  externalId  Int      @unique
  name        String
  photo       String?
  teamId      Int?
  team        Team?    @relation(fields: [teamId], references: [id])
}

model DreamTeam {
  id          Int      @id @default(autoincrement())
  userId      Int      
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitionId Int   
  competition Competition  @relation(fields: [competitionId], references: [id])
  
  formation   String   @default("1-2-1") // E.g., 1-2-1, 1-1-2, 2-1-1
  updatedAt   DateTime @updatedAt

  gkId        Int?
  gk          Player?  @relation("GK", fields: [gkId], references: [id])
  def1Id      Int?
  def1        Player?  @relation("DEF1", fields: [def1Id], references: [id])
  def2Id      Int?
  def2        Player?  @relation("DEF2", fields: [def2Id], references: [id])
  mid1Id      Int?
  mid1        Player?  @relation("MID1", fields: [mid1Id], references: [id])
  mid2Id      Int?
  mid2        Player?  @relation("MID2", fields: [mid2Id], references: [id])
  fwd1Id      Int?
  fwd1        Player?  @relation("FWD1", fields: [fwd1Id], references: [id])
  fwd2Id      Int?
  fwd2        Player?  @relation("FWD2", fields: [fwd2Id], references: [id])

  @@unique([userId, competitionId])
}

model OutrightPrediction {
  id                Int      @id @default(autoincrement())
  userId            Int      
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitionId     Int   
  competition       Competition  @relation(fields: [competitionId], references: [id])
  
  championTeam      String?
  runnerUpTeam      String?
  
  topScorerId       Int?
  topScorer         Player?  @relation("TopScorer", fields: [topScorerId], references: [id])
  bestPlayerId      Int?
  bestPlayer        Player?  @relation("BestPlayer", fields: [bestPlayerId], references: [id])

  updatedAt         DateTime @updatedAt

  @@unique([userId, competitionId])
}

model PlayerCompetitionStats {
  id            Int         @id @default(autoincrement())
  playerId      Int
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  competitionId Int
  competition   Competition @relation(fields: [competitionId], references: [id])

  goals         Int         @default(0)
  assists       Int         @default(0)
  cleanSheets   Int         @default(0)
  totalPoints   Int         @default(0)

  @@unique([playerId, competitionId])
  @@index([competitionId])
}
