generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  ADMIN
  SUPERADMIN
}

// MatchStatus enum eliminado — ya no hay tabla Match

model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  username      String        @unique
  password      String
  displayName   String
  avatar        String?
  role          Role          @default(PLAYER)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Theme selection (references predefined theme catalog)
  themeId           String    @default("default")

  predictions   Prediction[]
  groupUsers        GroupUser[]
  favorites         Favorite[]
  messages          Message[]
  dreamTeams        DreamTeam[]
  outrightPredictions OutrightPrediction[]

  // Fantasy Reverse Relations
  fantasyOwnedLeagues FantasyLeague[] @relation("FantasyLeagueOwner")
  fantasyTeams        FantasyTeam[]

  @@index([email])
  @@index([username])
}

// Para equipos/selecciones favoritas
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  teamName  String   // Ej: "Argentina", "Brasil"
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, teamName])
}

model Competition {
  id          Int      @id @default(autoincrement())
  externalId  Int
  name        String
  logo        String?
  season      Int      @default(2022)
  
  groups      Group[]
  dreamTeams  DreamTeam[]
  outrights   OutrightPrediction[]
  playerStats PlayerCompetitionStats[]
  predictions Prediction[]

  @@unique([externalId, season])
}

model Group {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
  inviteCode    String        @unique @default(uuid())
  isPublic      Boolean       @default(false)
  createdById   Int


  logoUrl         String?

  // Modulos extra permitidos
  allowMoreShots      Boolean @default(true)
  allowMoreCorners    Boolean @default(true)
  allowMorePossession Boolean @default(true)
  allowMoreFouls      Boolean @default(true)
  allowMoreCards      Boolean @default(true)
  allowMoreOffsides   Boolean @default(true)
  allowMoreSaves      Boolean @default(true)

  competitionId Int
  competition   Competition   @relation(fields: [competitionId], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  groupUsers    GroupUser[]
  messages      Message[]

  @@index([inviteCode])
}

model GroupUser {
  id            Int           @id @default(autoincrement())
  userId        Int
  groupId       Int
  totalPoints   Int           @default(0)
  joinedAt      DateTime      @default(now())
  isAdmin       Boolean       @default(false)
  isBanned      Boolean       @default(false)
  bannedAt      DateTime?

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group         Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId, totalPoints(sort: Desc)])
}

model Team {
  id          Int      @id @default(autoincrement())
  externalId  Int
  source      String   @default("api-football") // 'sportmonks' | 'api-football'
  name        String
  code        String?
  logo        String?
  country     String?
  flag        String?
  
  players     Player[]
  coaches     Coach[]
  
  @@unique([externalId, source])
  @@index([externalId])
}

// Match/MatchEvent legacy ELIMINADOS — la data de partidos de API-Football viene del Explorer cache
// Para Sportmonks, los partidos se persisten en el model Fixture (ver abajo)

model Prediction {
  id                  Int           @id @default(autoincrement())
  userId              Int
  externalFixtureId   String        // ID del fixture en la API externa (Sportmonks o API-Football)
  source              String        @default("api-football") // 'sportmonks' | 'api-football'
  competitionId       Int           // Liga/torneo al que pertenece

  homeGoals       Int?
  awayGoals       Int?
  winner          String?
  doubleChance    String?

  btts            Boolean?
  overUnder25     String?
  moreShots       String?
  moreCorners     String?   // HOME, AWAY, EQUAL
  morePossession  String?   // HOME, AWAY, EQUAL
  moreFouls       String?   // HOME, AWAY, EQUAL
  moreCards       String?   // HOME, AWAY, EQUAL
  moreOffsides    String?   // HOME, AWAY, EQUAL
  moreSaves       String?   // HOME, AWAY, EQUAL

  isJoker         Boolean   @default(false)
  
  basePoints      Int       @default(0)
  pointsEarned    Int       @default(0)
  moreShotsHit    Boolean?  // null=not calculated, true=correct, false=wrong
  moreCornersHit  Boolean?
  morePossessionHit Boolean?
  moreFoulsHit    Boolean?
  moreCardsHit    Boolean?
  moreOffsidesHit Boolean?
  moreSavesHit    Boolean?
  isCalculated    Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  competition     Competition @relation(fields: [competitionId], references: [id])

  @@unique([userId, externalFixtureId, source]) 
  @@index([externalFixtureId])
  @@index([userId])
  @@index([competitionId])
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  userId    Int
  groupId   Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model ScoringConfig {
  id            Int      @id @default(autoincrement())
  exactScore    Int      @default(5)
  correctWinner Int      @default(2)
  doubleChance  Int      @default(0) // Legacy
  btts          Int      @default(0) // Legacy
  moreShots     Int      @default(1)
  moreCorners   Int      @default(1)
  morePossession Int     @default(1)
  moreFouls     Int      @default(1)
  moreCards     Int      @default(1)
  moreOffsides  Int      @default(1)
  moreSaves     Int      @default(1)
  overUnder     Int      @default(0) // Legacy
}

model Player {
  id          Int      @id @default(autoincrement())
  externalId  Int?
  source      String   @default("api-football") // 'sportmonks' | 'api-football'
  name        String
  teamId      Int?
  team        Team?    @relation(fields: [teamId], references: [id])
  country     String
  position    String   // GK, DEF, MID, FWD
  image       String?
  photo       String?  // URL from API
  number      Int?
  age         Int?
  price       Float?   // Optional for budget caps
  
  // Stats por competencia (tabla separada)
  stats       PlayerCompetitionStats[]

  // Reverse relations to DreamTeam slots
  gkTeams     DreamTeam[] @relation("GK")
  def1Teams   DreamTeam[] @relation("DEF1")
  def2Teams   DreamTeam[] @relation("DEF2")
  mid1Teams   DreamTeam[] @relation("MID1")
  mid2Teams   DreamTeam[] @relation("MID2")
  fwd1Teams   DreamTeam[] @relation("FWD1")
  fwd2Teams   DreamTeam[] @relation("FWD2")

  // Reverse relations to Outrights
  topScorers  OutrightPrediction[] @relation("TopScorer")
  bestPlayers OutrightPrediction[] @relation("BestPlayer")

  @@unique([externalId, source])
  @@index([teamId])
}

model Coach {
  id          Int      @id @default(autoincrement())
  externalId  Int      @unique
  name        String
  photo       String?
  teamId      Int?
  team        Team?    @relation(fields: [teamId], references: [id])
}

// ═══════════════════════════════════════════════════════════════
// SPORTMONKS — Modelos de persistencia para partidos y stats
// ═══════════════════════════════════════════════════════════════

model Fixture {
  id          String   @id @default(cuid())
  externalId  String
  source      String   // 'sportmonks' | 'api-football'
  leagueId    Int
  seasonId    Int?
  homeTeamId  Int
  awayTeamId  Int
  startTime   DateTime
  status      String   // 'scheduled' | 'live' | 'finished' | 'cancelled' | 'postponed'
  homeScore   Int?
  awayScore   Int?
  isLive      Boolean  @default(false)
  round       String?
  venueName   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playerStats PlayerMatchStat[]
  events      FixtureEvent[]

  @@unique([externalId, source])
  @@index([leagueId])
  @@index([startTime])
  @@index([isLive])
  @@index([status])
}

model PlayerMatchStat {
  id              String   @id @default(cuid())
  fixtureId       String
  playerId        Int
  teamId          Int
  rating          Float?
  goals           Int?
  assists         Int?
  minutesPlayed   Int?
  yellowCards     Int?
  redCards        Int?
  shotsOnTarget   Int?
  passesCompleted Int?
  passesAttempted Int?
  saves           Int?
  ownGoals        Int?
  jerseyNumber    Int?
  position        String?
  playerName      String?
  // ── Expanded stats (v2) ──
  tackles         Int?
  interceptions   Int?
  clearances      Int?
  keyPasses       Int?
  dribblesWon     Int?
  duelsWon        Int?
  accurateCrosses Int?
  foulsCommitted  Int?
  foulsDrawn      Int?
  penaltyMissed   Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fixture         Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@unique([fixtureId, playerId])
  @@index([playerId])
}

model FixtureEvent {
  id          String   @id @default(cuid())
  fixtureId   String
  minute      Int
  extraMinute Int?
  type        String   // 'goal' | 'card' | 'subst' | 'var' | 'other'
  detail      String?
  playerName  String?
  assistName  String?
  teamId      Int?
  createdAt   DateTime @default(now())

  fixture     Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@index([fixtureId])
}

model ExternalIdMapping {
  id              String  @id @default(cuid())
  entityType      String  // 'fixture' | 'team' | 'player'
  sportmonksId    String?
  apiFootballId   String?
  internalId      String

  @@index([entityType, sportmonksId])
  @@index([entityType, apiFootballId])
}

model DreamTeam {
  id          Int      @id @default(autoincrement())
  userId      Int      
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitionId Int   
  competition Competition  @relation(fields: [competitionId], references: [id])
  
  formation   String   @default("1-2-1") // E.g., 1-2-1, 1-1-2, 2-1-1
  updatedAt   DateTime @updatedAt

  gkId        Int?
  gk          Player?  @relation("GK", fields: [gkId], references: [id])
  def1Id      Int?
  def1        Player?  @relation("DEF1", fields: [def1Id], references: [id])
  def2Id      Int?
  def2        Player?  @relation("DEF2", fields: [def2Id], references: [id])
  mid1Id      Int?
  mid1        Player?  @relation("MID1", fields: [mid1Id], references: [id])
  mid2Id      Int?
  mid2        Player?  @relation("MID2", fields: [mid2Id], references: [id])
  fwd1Id      Int?
  fwd1        Player?  @relation("FWD1", fields: [fwd1Id], references: [id])
  fwd2Id      Int?
  fwd2        Player?  @relation("FWD2", fields: [fwd2Id], references: [id])

  @@unique([userId, competitionId])
}

model OutrightPrediction {
  id                Int      @id @default(autoincrement())
  userId            Int      
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitionId     Int   
  competition       Competition  @relation(fields: [competitionId], references: [id])
  
  championTeam      String?
  runnerUpTeam      String?
  
  topScorerId       Int?
  topScorer         Player?  @relation("TopScorer", fields: [topScorerId], references: [id])
  bestPlayerId      Int?
  bestPlayer        Player?  @relation("BestPlayer", fields: [bestPlayerId], references: [id])

  updatedAt         DateTime @updatedAt

  @@unique([userId, competitionId])
}

model PlayerCompetitionStats {
  id            Int         @id @default(autoincrement())
  playerId      Int
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  competitionId Int
  competition   Competition @relation(fields: [competitionId], references: [id])

  goals         Int         @default(0)
  assists       Int         @default(0)
  cleanSheets   Int         @default(0)
  totalPoints   Int         @default(0)

  @@unique([playerId, competitionId])
  @@index([competitionId])
}

// ═══════════════════════════════════════════════════════════════
// FANTASY FOOTBALL — Modelos principales
// ═══════════════════════════════════════════════════════════════

model FantasyLeague {
  id            String   @id @default(cuid())
  name          String
  description   String?
  code          String   @unique  // código de invitación de 6 chars
  ownerId       Int
  leagueId      Int      // Liga de fútbol (636, 8, 564, 384)
  seasonId      Int      // Temporada de Sportmonks
  status        String   @default("active") // active | finished
  maxTeams      Int      @default(20)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner         User           @relation("FantasyLeagueOwner", fields: [ownerId], references: [id])
  teams         FantasyTeam[]
  gameweeks     FantasyGameweek[]
}

model FantasyGameweek {
  id              String   @id @default(cuid())
  fantasyLeagueId String
  gameweekNumber  Int      // Fecha 1, 2, 3...
  roundId         Int?     // ID de ronda en Sportmonks
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(false)
  isFinished      Boolean  @default(false)
  transfersOpen   Boolean  @default(true)
  createdAt       DateTime @default(now())

  fantasyLeague   FantasyLeague  @relation(fields: [fantasyLeagueId], references: [id])
  picks           FantasyPick[]
  playerScores    FantasyPlayerScore[]
  idealTeam       IdealTeamEntry[]

  @@unique([fantasyLeagueId, gameweekNumber])
}

model FantasyTeam {
  id              String   @id @default(cuid())
  userId          Int
  fantasyLeagueId String
  name            String
  totalPoints     Int      @default(0)
  budgetRemaining Float    @default(100.0) // presupuesto en millones
  status          String   @default("active") // active | banned | frozen
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  fantasyLeague   FantasyLeague @relation(fields: [fantasyLeagueId], references: [id])
  picks           FantasyPick[]
  transfers       FantasyTransfer[]

  @@unique([userId, fantasyLeagueId])
}

model FantasyPick {
  id              String   @id @default(cuid())
  fantasyTeamId   String
  gameweekId      String
  playerId        Int      // ID Sportmonks del jugador
  playerName      String   // guardado para no depender de join
  playerPosition  String   // GK | DEF | MID | FWD
  playerTeamId    Int
  playerTeamName  String
  isCaptain       Boolean  @default(false)
  isViceCaptain   Boolean  @default(false)
  isBenched       Boolean  @default(false) // true = suplente en el fantasy
  purchasePrice   Float    // precio al momento de fichar
  points          Int?     // calculado post-partido
  createdAt       DateTime @default(now())

  fantasyTeam     FantasyTeam     @relation(fields: [fantasyTeamId], references: [id])
  gameweek        FantasyGameweek @relation(fields: [gameweekId], references: [id])

  @@unique([fantasyTeamId, gameweekId, playerId])
}

model FantasyPlayerScore {
  id              String   @id @default(cuid())
  playerId        Int      // ID Sportmonks
  playerName      String
  fixtureId       Int      // ID Sportmonks del partido
  gameweekId      String
  
  // Stats del partido (de Sportmonks)
  minutesPlayed   Int      @default(0)
  goals           Int      @default(0)
  assists         Int      @default(0)
  yellowCards     Int      @default(0)
  redCards        Int      @default(0)
  saves           Int      @default(0)
  penaltySaves    Int      @default(0)
  ownGoals        Int      @default(0)
  shotsOnTarget   Int      @default(0)
  cleanSheet      Boolean  @default(false)
  rating          Float?   // rating de Sportmonks
  position        String   // posición en ese partido
  
  // Puntos calculados por categoría (para transparencia)
  pointsGoals         Int  @default(0)
  pointsAssists       Int  @default(0)
  pointsCards         Int  @default(0)
  pointsCleanSheet    Int  @default(0)
  pointsSaves         Int  @default(0)
  pointsMinutes       Int  @default(0)
  pointsRatingBonus   Int  @default(0)
  pointsTotal         Int  @default(0) // suma final
  
  calculatedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  gameweek        FantasyGameweek @relation(fields: [gameweekId], references: [id])

  @@unique([playerId, fixtureId])
}

model FantasyTransfer {
  id              String   @id @default(cuid())
  fantasyTeamId   String
  gameweekId      String   // gameweek EN QUE se hace la transferencia
  playerOutId     Int
  playerOutName   String
  playerInId      Int
  playerInName    String
  transferredAt   DateTime @default(now())

  fantasyTeam     FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
}

model FantasyPlayer {
  id              String   @id @default(cuid())
  sportmonksId    Int      @unique
  name            String
  position        String   // GK | DEF | MID | FWD
  teamId          Int
  teamName        String
  leagueId        Int
  nationality     String?
  photoUrl        String?
  price           Float    @default(5.0) // precio en millones
  totalPoints     Int      @default(0)   // acumulado de la temporada
  avgPoints       Float    @default(0)
  selectedBy      Float    @default(0)   // % de equipos que lo tienen
  updatedAt       DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// SPORTMONKS ROUNDS — Rondas/Jornadas persistidas localmente
// ═══════════════════════════════════════════════════════════════

model SportmonksRound {
  id          String    @id @default(cuid())
  roundId     Int
  leagueId    Int
  seasonId    Int
  name        String
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([roundId, leagueId])
  @@index([leagueId])
  @@index([seasonId])
}

// ═══════════════════════════════════════════════════════════════
// CRON/SYSTEM LOGS — Reportes de tareas programadas
// ═══════════════════════════════════════════════════════════════

model CronJobLog {
  id          String   @id @default(cuid())
  module      String   // 'Sportmonks', 'Fantasy', 'Prode', 'System'
  jobName     String   // Nombre descriptivo de la tarea
  status      String   // 'success' | 'error' | 'warning'
  durationMs  Int      // Milisegundos que tardó en ejecutarse
  message     String   // Mensaje claro (ej: "Sincronizados 3 partidos")
  metadata    Json?    // Opcional para debug interno extra si hiciera falta
  createdAt   DateTime @default(now())

  @@index([module])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// IDEAL TEAM — 11 ideal de la fecha, calculado por cron
// ═══════════════════════════════════════════════════════════════

model IdealTeamEntry {
  id              String   @id @default(cuid())
  gameweekId      String
  formation       String   // "4-3-3", "4-4-2", etc.
  totalPoints     Int      @default(0) // suma total del equipo ideal

  // Datos del jugador
  playerId        Int      // Sportmonks ID
  playerName      String
  position        String   // GK | DEF | MID | FWD
  photoUrl        String?
  teamName        String?
  teamId          Int?
  pointsTotal     Int      @default(0)
  goals           Int      @default(0)
  assists         Int      @default(0)
  minutesPlayed   Int      @default(0)
  rating          Float?
  cleanSheet      Boolean  @default(false)

  calculatedAt    DateTime @default(now())

  gameweek        FantasyGameweek @relation(fields: [gameweekId], references: [id])

  @@unique([gameweekId, playerId])
  @@index([gameweekId])
}
